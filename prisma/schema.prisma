generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Waybill {
  id              String   @id @default(uuid())
  externalCode    String?  @map("external_code")
  receiverStore   String?  @map("receiver_store")
  receiverName    String?  @map("receiver_name")
  receiverPhone   String?  @map("receiver_phone")
  receiverAddress String?  @map("receiver_address")
  skuCode         String?  @map("sku_code")
  skuName         String?  @map("sku_name")
  quantity        Int?
  weight          Float?
  tempArea        String?  @map("temp_area")
  skuSpec         String?  @map("sku_spec")
  remark          String?
  batchId         String   @map("batch_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("waybills")
}

model MappingRule {
  id          String   @id @default(uuid())
  fingerprint String   @unique
  mappings    String   // JSON string of RuleConfig
  templateName String? @map("template_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("mapping_rules")
}
